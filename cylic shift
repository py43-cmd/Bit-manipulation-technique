// num % (1 << k) == num & ((1 << k) - 1)
// Demonstrates cyclic pattern with powers of 2
void modularArithmeticCyclic() {
    cout << "\n=== MODULAR ARITHMETIC CYCLIC PROPERTY ===" << endl;
    
    int num = 23;
    int k = 3;
    int divisor = (1 << k);  // 2^3 = 8
    int mask = divisor - 1;   // 7 (0111 in binary)
    
    cout << "Number: " << num << ", k: " << k << ", divisor: " << divisor << endl;
    cout << "Using modulo: " << (num % divisor) << endl;
    cout << "Using bitwise AND: " << (num & mask) << endl;
    
    // Show cyclic pattern
    cout << "\nCyclic pattern (cycling every " << divisor << " numbers):" << endl;
    for (int i = 0; i < 20; i++) {
        cout << ((num + i) % divisor) << " ";
    }
    cout << endl;
}

