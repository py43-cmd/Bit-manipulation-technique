long long answer = 0;

for(int bit = 0; bit < 30; bit++) {
    long long zeros = 0, ones = 0;
    
    for(int i = 0; i < n; i++) {
        if(arr[i] & (1 << bit)) {
            ones++;
        } else {
            zeros++;
        }
    }
    
    // Pairs with different bits contribute to this bit position
    answer += zeros * ones * (1 << bit);
}
