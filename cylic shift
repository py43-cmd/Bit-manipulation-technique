// XOR property: a ^ x ^ x = a (returns to original after 2 XORs)
void xorCyclicDemo() {
    cout << "\n=== XOR CYCLIC PROPERTY ===" << endl;
    
    int a = 15;
    int x = 7;
    
    cout << "Original: " << a << endl;
    int after_first_xor = a ^ x;
    cout << "After XOR with " << x << ": " << after_first_xor << endl;
    
    int after_second_xor = after_first_xor ^ x;
    cout << "After XOR with " << x << " again: " << after_second_xor << endl;
    cout << "Back to original: " << (after_second_xor == a ? "YES" : "NO") << endl;
}

// Swap two numbers using XOR (cyclic property)
void swapUsingXOR(int& a, int& b) {
    a = a ^ b;  // a now contains a^b
    b = a ^ b;  // b now contains (a^b)^b = a
    a = a ^ b;  // a now contains (a^b)^a = b
}

// ============================================================================
// 3. GRAY CODE - CYCLIC NEIGHBORS (Each consecutive number differs by 1 bit)
// ============================================================================

// Convert binary to Gray code
int binaryToGray(int n) {
    return n ^ (n >> 1);
}

// Convert Gray code back to binary
int grayToBinary(int gray) {
    int binary = gray;
    while (gray) {
        gray >>= 1;
        binary ^= gray;
    }
    return binary;
}

// Hamming distance (number of different bits)
int hammingDistance(int x, int y) {
    int xor_result = x ^ y;
    return __builtin_popcount(xor_result);
}

