// ============================================================================

// Find cycle length when rotating bits
int findRotationCycleLength(int num, int rotateBits) {
    int original = num;
    int count = 0;
    
    do {
        num = leftRotate(num, rotateBits);
        count++;
        if (count > 100) break;  // Safety check
    } while (num != original && count < 100);
    
    return count;
}

