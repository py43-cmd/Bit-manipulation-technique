// ============================================================================
// 1. BIT ROTATION - LEFT AND RIGHT ROTATION
// ============================================================================

// Left rotate by k positions (cyclic property: after 32 rotations, returns to original)
int leftRotate(int num, int k) {
    int n = 32;  // for 32-bit integer
    k = k % n;   // Cyclic: k % n (key cyclic property!)
    return (num << k) | (num >> (n - k));
}

// Right rotate by k positions
int rightRotate(int num, int k) {
    int n = 32;
    k = k % n;
    return (num >> k) | (num << (n - k));
}

// Left rotate for 64-bit long long
long long leftRotate64(long long num, int k) {
    int n = 64;
    k = k % n;
    return (num << k) | (num >> (n - k));
}

